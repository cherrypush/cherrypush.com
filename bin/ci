#!/usr/bin/env bash
set -uo pipefail

# TODO: migrate to ActiveSupport::ContinuousIntegration once on Rails 8

# Colored output helpers
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FAILED=0

step() {
  local label="$1"
  shift
  printf "${YELLOW}=> %s${NC}\n" "$label"
  if "$@"; then
    printf "${GREEN}   ✔ %s${NC}\n\n" "$label"
  else
    printf "${RED}   ✘ %s${NC}\n\n" "$label"
    FAILED=1
  fi
}

# Setup
if [ "${CI:-}" = "true" ]; then
  step "Setup: Dependencies" npm install --frozen-lockfile
  step "Setup: Database" bin/rails db:test:prepare
else
  step "Setup: Dependencies" bundle install
  step "Setup: Dependencies" npm install
  step "Setup: Database" bin/rails db:test:prepare
fi

# Linting
[ $FAILED -eq 0 ] && step "Style: Ruby" bundle exec rubocop
[ $FAILED -eq 0 ] && step "Style: JS/TS lint" npx eslint app/javascript/
[ $FAILED -eq 0 ] && step "Style: Formatting" npx prettier --check .

# Tests
[ $FAILED -eq 0 ] && step "Tests: Rails" bin/rails test
[ $FAILED -eq 0 ] && step "Tests: System" HEADLESS=1 bin/rails test:system

# Result
if [ $FAILED -ne 0 ]; then
  printf "\n${RED}CI failed.${NC} Fix the issues and try again.\n"
  exit 1
else
  printf "\n${GREEN}CI passed.${NC}\n"
fi
